generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model test {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
}

model images {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  url        String
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model gallery {
  id          BigInt    @id @default(autoincrement())
  title       String
  category    String
  image       String
  description String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model instagram_posts {
  id         BigInt    @id @default(autoincrement())
  image      String
  likes      Int?      @default(0)
  comments   Int?      @default(0)
  post_link  String?
  post_date  DateTime? @db.Date
  caption    String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model projects {
  id                          BigInt    @id @default(autoincrement())
  title                       String
  subtitle                    String?
  category                    String
  location                    String?
  year                        String?
  area                        String?
  photographer                String?
  client                      String?
  hero_image                  String
  description                 String
  images                      String[]  @default([])
  content                     Json?     @default("[]")
  latitude                    Float?
  longitude                   Float?
  youtube_walkthrough_heading String?
  youtube_walkthrough_link    String?
  featured                    Boolean?  @default(false)
  created_at                  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at                  DateTime? @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model testimonials {
  id         BigInt    @id @default(autoincrement())
  name       String
  role       String?
  company    String?
  image      String?
  rating     Int?      @default(5)
  text       String
  featured   Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model jobs {
  id               BigInt    @id @default(autoincrement())
  title            String
  department       String?
  location         String?
  type             String?
  description      String
  requirements     String[]  @default([])
  responsibilities String[]  @default([])
  is_active        Boolean?  @default(true)
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  updated_at       DateTime? @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model employees {
  id          BigInt    @id @default(autoincrement())
  name        String
  role        String
  imageurl    String
  description String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
}

model employee_profiles {
  id                Int       @id @default(autoincrement())
  auth_user_id      String    @unique @db.Uuid
  full_name         String
  email             String
  phone             String?
  employee_id       String    @unique
  role              String
  approval_status   String    @default("pending")
  disabled          Boolean   @default(false)
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)
  salary_structures employee_salary_structure[]
  attendance        attendance_records[]
  payslips          payslips[]
}

model salary_components {
  id                Int       @id @default(autoincrement())
  name              String    @unique
  type              String
  attendance_based  Boolean   @default(false)
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  salary_structures employee_salary_structure[]
}

model employee_salary_structure {
  id                  Int               @id @default(autoincrement())
  employee_profile_id Int
  component_id        Int
  amount              Decimal           @db.Decimal(12, 2)
  created_at          DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?         @default(now()) @db.Timestamptz(6)
  employee_profile    employee_profiles @relation(fields: [employee_profile_id], references: [id], onDelete: Cascade)
  salary_component    salary_components @relation(fields: [component_id], references: [id], onDelete: Cascade)
  @@unique([employee_profile_id, component_id])
}

model attendance_records {
  id                  Int               @id @default(autoincrement())
  employee_profile_id Int
  date                DateTime          @db.Date
  check_in_time       DateTime          @default(now()) @db.Timestamptz(6)
  status              String            @default("present")
  created_at          DateTime?         @default(now()) @db.Timestamptz(6)
  employee_profile    employee_profiles @relation(fields: [employee_profile_id], references: [id], onDelete: Cascade)
  @@unique([employee_profile_id, date])
}

model payslips {
  id                  Int               @id @default(autoincrement())
  employee_profile_id Int
  month               String
  basic_salary        Decimal           @db.Decimal(12, 2)
  hra                 Decimal           @db.Decimal(12, 2)
  travel_allowance    Decimal           @db.Decimal(12, 2)
  bonus               Decimal           @db.Decimal(12, 2)
  pf_deduction        Decimal           @db.Decimal(12, 2)
  tax_deduction       Decimal           @db.Decimal(12, 2)
  other_earnings      Decimal           @db.Decimal(12, 2)
  other_deductions    Decimal           @db.Decimal(12, 2)
  custom_components   Json              @default("{}")
  total_present_days  Int
  total_working_days  Int
  gross_salary        Decimal           @db.Decimal(12, 2)
  total_deductions    Decimal           @db.Decimal(12, 2)
  net_salary          Decimal           @db.Decimal(12, 2)
  created_at          DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?         @default(now()) @db.Timestamptz(6)
  employee_profile    employee_profiles @relation(fields: [employee_profile_id], references: [id], onDelete: Cascade)
  @@unique([employee_profile_id, month])
}

